<?xml version="1.0" encoding="utf-8"?>
<!--
    3×3 grid drawn as an outline (outer border + 2 internal dividers each way),
    not filled squares. 108×108 canvas, grid box spans 33–75 (42×42), centered,
    leaving a generous white margin on all sides so it reads as framed rather
    than edge-to-edge. Divider lines at 33+14=47 and 33+28=61.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:pathData="M33,33 H75 V75 H33 Z
                           M47,33 V75
                           M61,33 V75
                           M33,47 H75
                           M33,61 H75"
        android:strokeColor="#000000"
        android:strokeWidth="4"
        android:strokeLineCap="square"
        android:fillColor="@android:color/transparent" />

</vector>
